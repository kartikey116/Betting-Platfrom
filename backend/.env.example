# Server port
PORT=5000

# PostgreSQL Connection String (Supabase or Local)
# Example Supabase format: postgresql://postgres.xxxxxxxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://user:password@localhost:5432/betting_db

# JWT Secret for authentication
JWT_SECRET=super_secret_jwt_key_here
